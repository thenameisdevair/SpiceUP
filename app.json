{
  "expo": {
    "name": "SpiceUP",
    "slug": "spiceup",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/857d289d-a15e-4182-80e2-5fd72e397821"
    },
    "scheme": "spiceup",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "bundleIdentifier": "com.spiceup.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "SpiceUP uses your camera to scan payment addresses."
      }
    },
    "android": {
      "package": "com.spiceup.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "857d289d-a15e-4182-80e2-5fd72e397821"
      },
      "router": {}
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SpiceUP to scan QR codes for payments."
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "newArchEnabled": true,
            "minSdkVersion": 24,
            "compileSdkVersion": 36,
            "targetSdkVersion": 34
          }
        }
      ]
    ],
    "owner": "devairmd"
  }
}
